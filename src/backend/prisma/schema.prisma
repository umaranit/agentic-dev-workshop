generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// PRE-BUILT — do not modify
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

// All domain models are added during the workshop.
// The design-agent produces schema additions based on the BRD and Issues.
// The Coding Agent runs migrations when assigned the [DATABASE] Issue.
